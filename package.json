{
  "name": "classmatejs",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build:all": "npm run build -ws --if-present",
    "build:react": "npm run build -w @classmatejs/react",
    "build:solid": "npm run build -w @classmatejs/solid",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "test:all": "npm run test:react && npm run test:solid",
    "test:react": "npm run test:src -w @classmatejs/react",
    "test:solid": "npm run test -w @classmatejs/solid",
    "typecheck:all": "npm run typecheck -ws --if-present",
    "typecheck:react": "npm run typecheck -w @classmatejs/react",
    "typecheck:solid": "npm run typecheck -w @classmatejs/solid",
    "publish:react": "npm run test:react && npm run package -w @classmatejs/react",
    "publish:solid": "npm run test:solid && npm run package -w @classmatejs/solid",
    "publish:all": "npm run publish:react && npm run publish:solid",
    "verify": "npm run lint && npm run typecheck:all && npm run test:all",
    "docs:dev": "npm run dev -w @classmatejs/docs",
    "docs:build": "npm run build -w @classmatejs/docs",
    "docs:preview": "npm run build -w @classmatejs/docs && npm run preview -w @classmatejs/docs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "typescript": "^6.0.3",
    "lefthook": "^2.1.10"
  },
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richard-unterberg/classmatejs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/richard-unterberg/classmatejs/issues"
  },
  "homepage": "https://github.com/richard-unterberg/classmatejs#readme"
}
