{
  "name": "@marmo/react",
  "description": "A react tool to separate class name logic, create variants and manage styles.",
  "version": "1.0.0",
  "keywords": [
    "react",
    "marmo",
    "typescript",
    "dynamic-classnames",
    "dynamic-styles",
    "dynamic-variants",
    "css",
    "css-in-js",
    "utility-first",
    "utility-first-classnames",
    "classname",
    "classname-variants",
    "frontend",
    "ssr",
    "tailwind",
    "unocss",
    "tailwind-merge"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richard-unterberg/classmatejs.git"
  },
  "bugs": {
    "url": "https://github.com/richard-unterberg/classmatejs/issues"
  },
  "homepage": "https://github.com/richard-unterberg/classmatejs/tree/main/packages/react#readme",
  "scripts": {
    "========= Test": "",
    "test-clear": "jest --clearCache",
    "test:all": "npm run test-clear && npm run test:src",
    "test:src": "jest --config jest.config.cjs --testPathPattern=test/src",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.types.json",
    "========= Build": "",
    "build:base": "tsup",
    "build": "npm run build:base",
    "package": "npm run build && npm publish --access public"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "dependencies": {
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "tsx": "^4.23.0",
    "tsup": "^8.5.1"
  }
}
