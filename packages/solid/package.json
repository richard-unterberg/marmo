{
  "name": "@marmo/solid",
  "description": "A solidjs tool to separate class name logic, create variants and manage styles.",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richard-unterberg/marmo.git"
  },
  "bugs": {
    "url": "https://github.com/richard-unterberg/marmo/issues"
  },
  "homepage": "https://github.com/richard-unterberg/marmo/tree/master/packages/solid#readme",
  "keywords": [
    "solid",
    "solidjs",
    "marmo",
    "typescript",
    "dynamic-classnames",
    "dynamic-styles",
    "dynamic-variants",
    "css",
    "css-in-js",
    "utility-first",
    "utility-first-classnames",
    "classname",
    "classname-variants",
    "frontend",
    "ssr",
    "tailwind",
    "unocss",
    "tailwind-merge"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.ssr.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.types.json",
    "========= Build": "",
    "package": "npm run build && npm publish --access public"
  },
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "dependencies": {
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "solid-js": "^1.9.14",
    "tsup": "^8.5.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  }
}
